# Google service-account credentials as a single-line JSON blob, scoped for
# Sheets + Drive read access. Read lazily on every sheet fetch by
# config.get_google_credentials_json(); required for the backend to serve data.
GOOGLE_CREDENTIALS=

# Port the local Flask dev server binds to (config.get_port(), default 8080).
# In production the Procfile runs gunicorn --bind 0.0.0.0:${PORT:-8000}.
PORT=8080
